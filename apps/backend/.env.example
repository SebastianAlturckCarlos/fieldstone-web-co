# Fieldstone Agentic OS — backend configuration
# Copy this file to .env (`cp .env.example .env`). Every default below is the
# SAFE one: dry-run agents, mock sends, $0 cost, no network. Read the cost
# model in ../README.md before changing AGENT_MODE.

# ── Who does the thinking ─────────────────────────────────────────────────
# dry-run      canned mock outputs, deterministic, no network. $0, always.
# claude-code  shells out to your installed `claude` CLI — runs on the Claude
#              subscription. Hits the usage limit -> stops. Never bills extra.
# api          Anthropic API, pay-per-token. REAL MONEY. Refuses to run unless
#              BOTH ALLOW_PAID_API=true and ANTHROPIC_API_KEY are set — a
#              deliberate double opt-in so it can never trigger by accident.
AGENT_MODE=dry-run
ALLOW_PAID_API=false
#ANTHROPIC_API_KEY=

# ── Budget guardrails (enforced by the ledger in api mode) ────────────────
DAILY_TOKEN_BUDGET_USD=5
PER_LEAD_BUDGET_USD=0.25

# ── Pipeline behavior ─────────────────────────────────────────────────────
# QA_THRESHOLD: CEO approve score (0-100). AUTO_TICK: the server ticks itself
# whenever leads are pending (interval AUTO_TICK_MS, default 60s).
QA_THRESHOLD=80
AUTO_TICK=true
AUTO_TICK_MS=60000

# ── Outreach (Sprint 3) ───────────────────────────────────────────────────
# SEND_MODE=mock stamps emails as sent in the DB, delivers nowhere ($0).
# SEND_MODE=resend sends for real — requires RESEND_API_KEY and
# BUSINESS_POSTAL_ADDRESS (CAN-SPAM footer; startup fails without it).
SEND_MODE=mock
#RESEND_API_KEY=
SEND_FROM=sebastian@mail.fieldstone-webco.com
DAILY_SEND_CAP=10
#BUSINESS_POSTAL_ADDRESS=
# mail.fieldstone-webco.com has no inbox/MX — set REPLY_TO to a real mailbox
# or every prospect reply bounces. Remove once real inbound routing exists.
#REPLY_TO=

# Injected into agent prompts: {{demo_link}} (CMO) and {{calendar_link}}
# (Sales Rep positive-reply drafts — Cal.com / Calendly URL).
#DEMO_LINK=
#CALENDAR_LINK=

# ── Integrations ──────────────────────────────────────────────────────────
# SITE_BASE: where the personalized /demo/ pages live (the marketing site).
SITE_BASE=https://fieldstone-webco.com
OLLAMA_URL=http://localhost:11434
DASHBOARD_API_PORT=4600
