# Copy to .env and edit. Everything has a safe default — an empty .env runs
# fully offline in dry-run mode at $0.
# NOTE: ^11 better-sqlite3 has no Node 24 prebuilds — package.json pins ^12,
# which installs cleanly on Node 20 and 24 both.

# dry-run (default) | claude-code (subscription, hard-stops, $0 extra) | api (PAYS PER TOKEN)
# NOTE: outside dry-run, every agent EXCEPT the Dev Agent runs on a free local
# Ollama model (hermes3:8b for research/QC/copy/consult/analytics, plus the
# Researcher's existing qwen2.5-coder:latest) — the whole per-lead loop costs
# $0 and never touches your Claude subscription's usage limit. claude-code is
# only the AUTOMATIC FALLBACK if Ollama is down, and the Dev Agent (weekly,
# low-frequency, code quality matters) always runs on the subscription.
# Before real copy: `ollama pull hermes3:8b` (~4.7GB) alongside qwen2.5-coder.
AGENT_MODE=dry-run

# api mode refuses to run unless BOTH of these are set — that's deliberate.
# ALLOW_PAID_API=true
# ANTHROPIC_API_KEY=sk-ant-...

DAILY_TOKEN_BUDGET_USD=5
PER_LEAD_BUDGET_USD=0.25
QA_THRESHOLD=80
AUTO_TICK=true
AUTO_TICK_MS=60000

# ── Outreach (Sprint 3) ──────────────────────────────────────────────────
# SEND_MODE=mock stamps the DB, delivers nowhere ($0). resend sends for real
# and requires RESEND_API_KEY + BUSINESS_POSTAL_ADDRESS (CAN-SPAM footer).
SEND_MODE=mock
# RESEND_API_KEY=
SEND_FROM=sebastian@mail.fieldstone-webco.com
# Shown as the inbox "From" name (Resend accepts "Name <email>") — a bare
# address reads as automated, a first name reads as a person.
SENDER_NAME=Sebastian
DAILY_SEND_CAP=10
# BUSINESS_POSTAL_ADDRESS=

# mail.fieldstone-webco.com has no inbox/MX — set REPLY_TO to a real mailbox
# or every prospect reply bounces. Remove once real inbound routing exists.
# REPLY_TO=

# Injected into agent prompts: {{calendar_link}} (Sales Rep follow-ups)
# CALENDAR_LINK=

# ── Branded preview snapshots ────────────────────────────────────────────
# Outreach emails embed a screenshot of the prospect's operations screen,
# themed with THEIR colors + logo (scraped during the audit). Rendering uses
# the Chrome/Edge already on this machine via puppeteer-core. Auto-detected;
# set explicitly only if detection fails. Snapshot failures never block the
# pipeline — the email just ships without the image.
# SNAPSHOT_BROWSER_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# SITE_BASE: where the /demo/ pages live (marketing site). Kept for the
# Sales Rep's booking flow; cold emails no longer carry live demo links —
# the embedded branded snapshot replaced them.
SITE_BASE=https://fieldstone-webco.com
OLLAMA_URL=http://localhost:11434
DASHBOARD_API_PORT=4600

# ── Production flip (the real thing) ─────────────────────────────────────
# Production = AGENT_MODE=claude-code + SEND_MODE=resend. Model-written copy,
# branded snapshot embedded, and every draft STILL stops in the CEO approval
# queue — nothing sends without a human click, and dispatch still enforces
# suppression, the daily cap, jitter, and the bounce circuit breaker.
# AGENT_MODE=claude-code
# SEND_MODE=resend
