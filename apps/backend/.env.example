# Copy to .env and edit. Everything has a safe default — an empty .env runs
# fully offline in dry-run mode at $0.
# NOTE: ^11 better-sqlite3 has no Node 24 prebuilds — package.json pins ^12,
# which installs cleanly on Node 20 and 24 both.

# dry-run (default) | claude-code (subscription, hard-stops, $0 extra) | api (PAYS PER TOKEN)
AGENT_MODE=dry-run

# api mode refuses to run unless BOTH of these are set — that's deliberate.
# ALLOW_PAID_API=true
# ANTHROPIC_API_KEY=sk-ant-...

DAILY_TOKEN_BUDGET_USD=5
PER_LEAD_BUDGET_USD=0.25
QA_THRESHOLD=80
AUTO_TICK=true
AUTO_TICK_MS=60000

# ── Outreach (Sprint 3) ──────────────────────────────────────────────────
# SEND_MODE=mock stamps the DB, delivers nowhere ($0). resend sends for real
# and requires RESEND_API_KEY + BUSINESS_POSTAL_ADDRESS (CAN-SPAM footer).
SEND_MODE=mock
# RESEND_API_KEY=
SEND_FROM=sebastian@mail.fieldstone-webco.com
DAILY_SEND_CAP=10
# BUSINESS_POSTAL_ADDRESS=

# mail.fieldstone-webco.com has no inbox/MX — set REPLY_TO to a real mailbox
# or every prospect reply bounces. Remove once real inbound routing exists.
# REPLY_TO=

# Injected into agent prompts: {{demo_link}} (CMO), {{calendar_link}} (Sales Rep)
# DEMO_LINK=
# CALENDAR_LINK=

# SITE_BASE: where the personalized /demo/ pages live (the marketing site)
SITE_BASE=https://fieldstone-webco.com
OLLAMA_URL=http://localhost:11434
DASHBOARD_API_PORT=4600
